{
  "name": "AekiAppi Flutter Dev",

  // Build the image from the Dockerfile in this directory.
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Mount the local workspace into the container.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/aeki_appi,type=bind,consistency=cached",
  "workspaceFolder": "/workspace/aeki_appi",

  // Forward adb port so a USB-connected Android device is accessible.
  // Forward 8080 for Flutter web dev server.
  "forwardPorts": [5037, 8080],
  "portsAttributes": {
    "5037": {
      "label": "Android Debug Bridge (adb)",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "Flutter Web Dev Server",
      "onAutoForward": "silent"
    }
  },

  // Prepare Android SDK components/licenses and fetch Dart packages.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Keep VS Code server binaries/data on the dedicated mounted volume.
  "remoteEnv": {
    "VSCODE_AGENT_FOLDER": "/vscode/vscode-server-insiders",
    "CHROME_EXECUTABLE": "/usr/bin/chromium-browser",
    "FLUTTER_ROOT": "/opt/flutter-sdk"
  },

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      // Keep these in sync with .vscode/extensions.json.
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "usernamehw.errorlens",
        "streetsidesoftware.code-spell-checker",
        "github.copilot",
        "github.copilot-chat",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "Dart-Code.dart-code",
        "[dart]": {
          "editor.formatOnSave": true,
          "editor.selectionHighlight": false,
          "editor.suggest.snippetsPreventQuickSuggestions": false,
          "editor.suggestSelection": "first",
          "editor.tabCompletion": "onlySnippets",
          "editor.wordBasedSuggestions": "off"
        },
        "dart.flutterSdkPath": "/opt/flutter-sdk",
        "dart.lineLength": 80,
        "dart.enableSdkFormatter": true,
        "dart.debugExternalPackageLibraries": false,
        "dart.debugSdkLibraries": false,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
