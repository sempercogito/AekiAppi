{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Run Web Server",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "web-server", "--web-port=8080"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Launching.*",
          "endsPattern": "^Flutter run key commands"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
